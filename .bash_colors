# A set of pre-defined color escape codes for use in prompts and with `echo`.s


# ---- preset print vars ----
OK=" [${GR}${B}ok${_X}]"
ERR=" [${RD}${B}error${_X}]"
WARN=" [${YW}${B}warn${_X}]"
USAGE=" [${CY}${B}usage${_X}]"
HELP="- ${MG}HELP${_X} -\n========"


BK="\[\e[0;30m\]"
RD="\[\e[0;31m\]"
GR="\[\e[0;32m\]"
YW="\[\e[0;33m\]"
BL="\[\e[0;34m\]"
MG="\[\e[0;35m\]"
CY="\[\e[0;36m\]"
WH="\[\e[0;37m\]"
OR="\[\e[0;91m\]"

B_BK="\[\e[30;1m\]"
B_RD="\[\e[31;1m\]"
B_GR="\[\e[32;1m\]"
B_YW="\[\e[33;1m\]"
B_BL="\[\e[34;1m\]"
B_MG="\[\e[35;1m\]"
B_CY="\[\e[36;1m\]"
B_WH="\[\e[37;1m\]"
B_OR="\[\e[91;1m\]"

UL_BK="\[\e[30;4m\]"
UL_RD="\[\e[31;4m\]"
UL_GR="\[\e[32;4m\]"
UL_YW="\[\e[33;4m\]"
UL_BL="\[\e[34;4m\]"
UL_MG="\[\e[35;4m\]"
UL_CY="\[\e[36;4m\]"
UL_WH="\[\e[37;4m\]"
UL_OR="\[\e[91;4m\]"

BG_BK="\[\e[40m\]"
BG_RD="\[\e[41m\]"
BG_GR="\[\e[42m\]"
BG_YW="\[\e[43m\]"
BG_BL="\[\e[44m\]"
BG_MG="\[\e[45m\]"
BG_CY="\[\e[46m\]"
BG_WH="\[\e[47;1m\]"
BG_OR="\[\e[101m\]"

_X="\[\e[0m\]"
_XC="\[\e[39m\]"

# These colors are meant to be used with `echo -e`
E_BK="\033[0;30m"
E_RD="\033[0;31m"
E_GR="\033[0;32m"
E_YW="\033[0;33m"
E_BL="\033[0;34m"
E_MG="\033[0;35m"
E_CY="\033[0;36m"
E_WH="\033[0;37;1m"
E_OR="\033[0;91m"

E_B_BK="\033[30;1m"
E_B_RD="\033[31;1m"
E_B_GR="\033[32;1m"
E_B_YW="\033[33;1m"
E_B_BL="\033[34;1m"
E_B_MG="\033[35;1m"
E_B_CY="\033[36;1m"
E_B_WH="\033[37;1m"
E_B_OR="\033[91;1m"

E_UL_BK="\033[30;4m"
E_UL_RD="\033[31;4m"
E_UL_GR="\033[32;4m"
E_UL_YW="\033[33;4m"
E_UL_BL="\033[34;4m"
E_UL_MG="\033[35;4m"
E_UL_CY="\033[36;4m"
E_UL_WH="\033[37;4m"
E_UL_OR="\033[91;4m"

E_BG_BK="\033[40m"
E_BG_RD="\033[41m"
E_BG_GR="\033[42m"
E_BG_YW="\033[43m"
E_BG_BL="\033[44m"
E_BG_MG="\033[45m"
E_BG_CY="\033[46m"
E_BG_WH="\033[47;1m"
E_BG_OR="\033[101m"

E_X="\033[0m"
E_XC="\033[39m"
